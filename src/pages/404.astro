---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · k8-one">
  <section class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist. Maybe it never did.</p>
    <p class="sub">Or maybe it's just in a different namespace.</p>
    <a href="/">← back to safety</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 1rem;
  }

  .not-found h1 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 5rem;
    color: var(--border);
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
    background: var(--drift-grad, var(--border));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .not-found p {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .not-found .sub {
    font-size: 0.9rem;
    color: var(--border);
    font-style: italic;
    margin-bottom: 2rem;
  }

  .not-found a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--accent);
    text-decoration: none;
  }

  .not-found a:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Slowly drifting poline gradient on the 404 text.
  import { Poline } from 'poline';

  const h1 = document.querySelector('.not-found h1') as HTMLElement;
  if (h1) {
    const startHue = Math.random() * 360;
    const p = new Poline({
      anchorColors: [
        [startHue, 0.5, 0.55],
        [(startHue + 120) % 360, 0.5, 0.55],
      ],
      numPoints: 4,
    });

    function update() {
      p.shiftHue(0.3);
      const css = p.colorsCSS;
      h1.style.setProperty('--drift-grad', `linear-gradient(135deg, ${css.join(', ')})`);
      requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }
</script>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
const words = post.body.split(/\s+/).length;
const readMin = Math.max(1, Math.round(words / 230));
---

<BaseLayout title={`${post.data.title} · k8-one`} description={post.data.description}>
  <script>
    // Per-visit color palette generated via poline for perceptually smooth gradients.
    import { Poline } from 'poline';

    // Constrain anchors for dark backgrounds: moderate sat (0.4-0.7), mid lightness (0.45-0.65).
    const startHue = Math.random() * 360;
    const p = new Poline({
      anchorColors: [
        [startHue, 0.4 + Math.random() * 0.3, 0.5 + Math.random() * 0.15],
        [(startHue + 80 + Math.random() * 120) % 360, 0.4 + Math.random() * 0.3, 0.5 + Math.random() * 0.15],
      ],
      numPoints: 4,
    });

    const css = p.colorsCSS;
    // css[0] = first anchor, css[last] = second anchor, middle = interpolated stops.
    const accent = css[0];
    const gold = css[css.length - 1];
    const gradStops = css.join(', ');

    const r = document.documentElement;
    r.style.setProperty('--accent', accent);
    r.style.setProperty('--gold', gold);
    r.style.setProperty('--accent-glow', accent.replace('hsl(', 'hsla(').replace(')', ', 0.12)'));
    r.style.setProperty('--heading-grad', `linear-gradient(135deg, ${gradStops})`);

    // Color post tag pills from the palette.
    const tags = document.querySelectorAll('.tag');
    tags.forEach((el, i) => {
      const ci = Math.floor((i / Math.max(tags.length, 1)) * css.length);
      const c = css[Math.min(ci, css.length - 1)];
      (el as HTMLElement).style.color = c;
    });

    // Blockquote border from warm end, inline code color from cool end.
    const warmColor = css[css.length - 1];
    const coolColor = css[0];
    r.style.setProperty('--blockquote-accent', warmColor);
    r.style.setProperty('--code-accent', coolColor);

    // Selection highlight from palette midpoint.
    const midColor = css[Math.floor(css.length / 2)];
    r.style.setProperty('--selection-color', midColor);
  </script>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span class="reading-time">· {readMin} min read</span>
        {post.data.tags.length > 0 && (
          <span class="tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}/`} class="tag">{tag}</a>
            ))}
          </span>
        )}
      </div>
    </header>
    
    <div class="content">
      <Content />
    </div>

    <nav class="post-nav">
      <a href="/" class="back-link">← all posts</a>
    </nav>
  </article>
</BaseLayout>

<style>
  article {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-header h1 {
    margin-bottom: 0.75rem;
    font-size: 1.8rem;
    background: var(--heading-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .meta time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .tags {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .reading-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    padding: 0.12rem 0.5rem;
    background: var(--border);
    color: var(--muted);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .tag:hover {
    color: var(--accent);
    text-decoration: none;
    opacity: 1;
  }

  .content {
    line-height: 1.85;
    font-size: 1.02rem;
  }

  .content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    background: var(--heading-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    background: var(--heading-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(ul), .content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--blockquote-accent, var(--accent));
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }

  .post-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .post-header h1 {
      font-size: 1.5rem;
    }

    .content {
      font-size: 0.95rem;
    }
  }
</style>
